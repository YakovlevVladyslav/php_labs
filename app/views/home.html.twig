{% extends "layouts/base.html.twig" %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<div style="text-align: center; margin-bottom: 40px;">
    <h1 style="color: #333; margin-bottom: 10px;">Профессиональный ремонт и обслуживание в AutoFix</h1>
    <p style="color: #666; font-size: 18px;">Найдите необходимую услугу и запишитесь на СТО прямо сейчас</p>
</div>

<form action="/" method="GET" style="background: #e9ecef; padding: 20px; border-radius: 5px; margin-bottom: 30px; display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap;">
    
    <div style="flex: 2; min-width: 250px;">
        <label style="font-weight: bold; display: block; margin-bottom: 5px; color: #495057;">Поиск по названию</label>
        <input type="text" name="search" value="{{ currentSearch }}" placeholder="Например: масло, диагностика..." style="width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; box-sizing: border-box;">
    </div>

    <div style="flex: 1; min-width: 180px;">
        <label style="font-weight: bold; display: block; margin-bottom: 5px; color: #495057;">Категория</label>
        <select name="category" style="width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; background: white;">
            <option value="">Все категории</option>
            {% for cat in categories %}
                <option value="{{ cat }}" {% if currentCategory == cat %}selected{% endif %}>{{ cat }}</option>
            {% endfor %}
        </select>
    </div>

    <div style="display: flex; gap: 10px;">
        <button type="submit" style="background: #007bff; color: white; border: none; padding: 10px 20px; font-weight: bold; border-radius: 4px; cursor: pointer;">
            Найти
        </button>
        {% if currentSearch or currentCategory %}
            <a href="/" style="background: #6c757d; color: white; text-decoration: none; padding: 10px 20px; font-weight: bold; border-radius: 4px; text-align: center;">
                Сбросить
            </a>
        {% endif %}
    </div>
</form>

<h3 style="border-bottom: 2px solid #dee2e6; padding-bottom: 10px; margin-bottom: 20px;">Доступные услуги:</h3>

{% if services %}
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
        {% for service in services %}
            <div style="border: 1px solid #dee2e6; border-radius: 5px; padding: 20px; background: #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.05); display: flex; flex-direction: column; justify-content: space-between;">
                <div>
                    <span style="font-size: 12px; font-weight: bold; background: #e2f0d9; color: #28a745; padding: 3px 8px; border-radius: 10px; text-transform: uppercase;">
                        {{ service.category }}
                    </span>
                    <h4 style="margin: 15px 0 10px 0; color: #212529; font-size: 18px;">{{ service.name }}</h4>
                    <p style="color: #6c757d; font-size: 14px; margin-bottom: 20px; line-height: 1.4;">{{ service.description }}</p>
                </div>
                
                <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #eee; padding-top: 15px;">
                    <span style="font-size: 18px; font-weight: bold; color: #28a745;">{{ service.price }} руб.</span>
                    <a href="/appointment/create?service_id={{ service.id }}" style="background: #007bff; color: white; text-decoration: none; padding: 7px 12px; border-radius: 4px; font-size: 14px; font-weight: bold;">
                        Записаться
                    </a>
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    <div style="text-align: center; padding: 40px; border: 1px dashed #ccc; background: #fafafa; border-radius: 5px;">
        <p style="font-size: 18px; color: #6c757d;">По вашему запросу ничего не найдено.</p>
        <a href="/" style="color: #007bff; font-weight: bold;">Показать все услуги</a>
    </div>
{% endif %}
{% endblock %}